[11.398, "o", "  [32m[ANALYSIS][0m\r\n"]
[11.698, "o", "    [33m\u25cf Engineer[0m: Models tie on accuracy; RF has higher variance. Recommend LR for tabular small-n.\r\n"]
[11.798, "o", "\r\n"]
